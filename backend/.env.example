# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000
MAX_BODY_SIZE=15mb
MAX_ROWS=50000
RATE_LIMIT_PER_MINUTE=20
LOG_LEVEL=info

# LLM provider: "mock" (no API key needed, deterministic offline mapping),
# "groq", or "openai".
LLM_PROVIDER=mock
LLM_REQUEST_TIMEOUT_MS=30000

# OpenAI (only required when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (only required when LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
